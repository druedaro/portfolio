---
import '../styles/global.css';
import Nav from '../components/Nav.jsx';
import Hero from '../components/Hero.jsx';
import Competencies from '../components/Competencies.jsx';
import Projects from '../components/Projects.jsx';
import Contact from '../components/Contact.jsx';
import Footer from '../components/Footer.jsx';
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio | Frontend Developer</title>
    <meta
      name="description"
      content="Portfolio de frontend developer y technical marketer construido con Astro, React y Tailwind."
    />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100">
    <main class="overflow-hidden pt-4 bg-slate-950">
      <Nav />
      <Hero />
      <Competencies />
      <Projects />
      <Contact />
      <Footer />
    </main>
  </body>
</html>
